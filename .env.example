# ============================================================
# ISTS — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to source control.
# ============================================================

# --- Database ---
# Async URL for FastAPI / SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://ists:ists_dev_password@db:5432/ists
# Sync URL for Celery Beat DatabaseScheduler (psycopg2 driver)
DATABASE_SYNC_URL=postgresql+psycopg2://ists:ists_dev_password@db:5432/ists

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me-in-production-use-32-random-bytes
ALGORITHM=HS256
JWT_EXPIRE_HOURS=8
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# --- Storage ---
# "local" for dev (files stored in backend/storage/), "s3" for prod
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/app/storage
S3_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- SMTP (MailHog catch-all for dev) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_ADDRESS=ists@local

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Application ---
LOG_LEVEL=INFO
ENVIRONMENT=development
